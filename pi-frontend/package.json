{
  "name": "@agegr/pi-web",
  "version": "0.6.18",
  "description": "Web UI for the pi coding agent",
  "license": "MIT",
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    "assets",
    "scripts",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 30141 --webpack",
    "dev:prewarmed": "node scripts/prewarm-dev.mjs & next dev -p 30141 --webpack",
    "dev:turbo": "next dev -p 30141 --turbopack",
    "build": "next build --webpack",
    "start": "next start -p 30141",
    "postinstall": "node scripts/postinstall-local-app.mjs",
    "app:install": "node scripts/install-app.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "app:install:mac": "node scripts/install-macos-app.mjs",
    "app:install:win": "node scripts/install-windows-shortcut.mjs",
    "lint": "eslint .",
    "smoke:api": "node scripts/smoke-api.mjs",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@lobehub/icons": "^5.6.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
